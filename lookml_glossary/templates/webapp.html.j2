<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LookML Glossary</title>
    <style>
        :root{--p:#4285f4;--met:#34a853;--dim:#fbbc04;--view:#9c27b0;--exp:#1a73e8;--bg:#f8f9fa;--card:#fff;--border:#dadce0;--text:#202124;--muted:#5f6368}
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);line-height:1.6}
        .container{max-width:1400px;margin:0 auto;padding:2rem}
        h1{color:var(--p);margin-bottom:.5rem;font-size:2rem}
        .subtitle{color:var(--muted);margin-bottom:2rem}
        /* Tabs */
        .tabs{display:flex;border-bottom:2px solid var(--border);margin-bottom:2rem;gap:0}
        .tab{padding:.75rem 1.5rem;cursor:pointer;border:none;background:none;font-size:1rem;color:var(--muted);border-bottom:3px solid transparent;transition:.2s}
        .tab:hover{color:var(--text)}
        .tab.active{color:var(--p);border-bottom-color:var(--p);font-weight:600}
        .tab-content{display:none}
        .tab-content.active{display:block}
        /* Summary cards */
        .summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:1rem;margin-bottom:2rem}
        .s-card{background:var(--card);border-radius:10px;padding:1rem;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,.08)}
        .s-card .num{font-size:2.2rem;font-weight:700;color:var(--p)}
        .s-card .lbl{font-size:.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
        /* Diagram */
        .diagram-wrap{background:var(--card);border-radius:12px;padding:2rem;box-shadow:0 1px 4px rgba(0,0,0,.08);overflow-x:auto;margin-bottom:2rem}
        .diagram{display:flex;flex-direction:column;gap:2rem;min-width:700px}
        .model-box{border:2px solid var(--p);border-radius:12px;padding:1.5rem}
        .model-label{font-size:1.1rem;font-weight:700;color:var(--p);margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
        .model-label::before{content:"";display:inline-block;width:12px;height:12px;background:var(--p);border-radius:3px}
        .explore-row{display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:1rem}
        .explore-box{border:2px solid var(--exp);border-radius:10px;padding:1rem;min-width:200px;flex:1}
        .explore-label{font-weight:600;color:var(--exp);margin-bottom:.5rem;font-size:.95rem}
        .arrow-down{text-align:center;color:var(--muted);font-size:1.2rem;margin:.5rem 0}
        .views-row{display:flex;gap:1.5rem;flex-wrap:wrap}
        .view-box{border:2px solid var(--view);border-radius:10px;padding:1rem;min-width:220px;flex:1;max-width:400px;overflow:hidden;word-break:break-word}
        .view-label{font-weight:600;color:var(--view);margin-bottom:.25rem;font-size:.95rem;overflow:hidden;text-overflow:ellipsis}
        .view-table{font-size:.8rem;color:var(--muted);margin-bottom:.75rem;font-family:monospace;overflow:hidden;text-overflow:ellipsis}
        .field-section{margin-bottom:.5rem}
        .field-section-title{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.25rem;display:flex;align-items:center;gap:.4rem}
        .field-section-title.metric{color:var(--met)}
        .field-section-title.dim{color:var(--dim)}
        .field-pill{display:inline-block;padding:2px 8px;border-radius:10px;font-size:.75rem;margin:2px;background:#e8eaed;color:var(--text)}
        .field-pill.metric{background:#e6f4ea;color:#1e8e3e}
        .field-pill.dim{background:#fef7e0;color:#e37400}
        /* Table */
        .toolbar{display:flex;gap:1rem;align-items:center;margin-bottom:1rem;flex-wrap:wrap}
        .search-box{flex:1;min-width:250px;padding:.6rem 1rem;border:1px solid var(--border);border-radius:24px;font-size:1rem}
        .search-box:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 2px rgba(66,133,244,.2)}
        .btn{padding:.6rem 1.2rem;border:none;border-radius:8px;font-size:.9rem;cursor:pointer;font-weight:600;transition:.2s}
        .btn-primary{background:var(--p);color:#fff}
        .btn-primary:hover{background:#1a73e8}
        .filter-group{display:flex;gap:.5rem;flex-wrap:wrap}
        .filter-btn{padding:4px 12px;border:1px solid var(--border);border-radius:16px;background:var(--card);font-size:.8rem;cursor:pointer;transition:.2s}
        .filter-btn.active{background:var(--p);color:#fff;border-color:var(--p)}
        table{width:100%;border-collapse:collapse;background:var(--card);border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08)}
        thead{background:#e8eaed}
        th{padding:.75rem 1rem;text-align:left;font-size:.8rem;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);white-space:nowrap}
        td{padding:.75rem 1rem;border-top:1px solid #f1f3f4;font-size:.9rem;vertical-align:top}
        tr:hover td{background:#f8f9fa}
        .badge{display:inline-block;padding:2px 8px;border-radius:12px;font-size:.72rem;font-weight:600;color:#fff}
        .badge-measure{background:var(--met)}
        .badge-dimension{background:var(--dim);color:var(--text)}
        td code{background:#e8eaed;padding:1px 5px;border-radius:4px;font-size:.82rem}
        td a{color:var(--p);text-decoration:none}
        td a:hover{text-decoration:underline}
        .links-list{list-style:none;padding:0;margin:0}
        .links-list li{margin:2px 0}
        .empty-state{text-align:center;padding:3rem;color:var(--muted)}
        /* Drift notification banner */
        .drift-banner{display:none;background:#fff3cd;border:1px solid #ffc107;border-radius:10px;padding:1rem 1.5rem;margin-bottom:1.5rem;position:relative;box-shadow:0 1px 4px rgba(0,0,0,.08)}
        .drift-banner.has-errors{background:#f8d7da;border-color:#f5c2c7}
        .drift-banner.no-drift{background:#d1e7dd;border-color:#badbcc}
        .drift-banner-title{font-weight:700;font-size:1rem;margin-bottom:.25rem;display:flex;align-items:center;gap:.5rem}
        .drift-banner-title .icon{font-size:1.2rem}
        .drift-banner .dismiss{position:absolute;top:.75rem;right:1rem;background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--muted);line-height:1}
        .drift-banner .dismiss:hover{color:var(--text)}
        .drift-summary{font-size:.9rem;color:var(--muted);margin-bottom:.5rem}
        .drift-details{margin-top:.5rem}
        .drift-details summary{cursor:pointer;font-size:.85rem;font-weight:600;color:var(--p);user-select:none}
        .drift-table{width:100%;border-collapse:collapse;margin-top:.5rem;font-size:.82rem}
        .drift-table th{text-align:left;padding:4px 8px;background:#e8eaed;font-size:.75rem;text-transform:uppercase;letter-spacing:.5px;color:var(--muted)}
        .drift-table td{padding:4px 8px;border-top:1px solid #f1f3f4}
        .drift-table .sev-error{color:#dc3545;font-weight:600}
        .drift-table .sev-warning{color:#e37400;font-weight:600}
        .drift-table .sev-info{color:var(--p);font-weight:600}
    </style>
</head>
<body>
<div class="container">
    <h1>LookML Glossary</h1>
    <p class="subtitle">Auto-generated from LookML model &mdash; {{ summary.total_terms }} terms</p>

    <div class="drift-banner" id="drift-banner">
        <button class="dismiss" id="drift-dismiss" title="Dismiss">&times;</button>
        <div class="drift-banner-title">
            <span class="icon" id="drift-icon"></span>
            <span id="drift-title"></span>
        </div>
        <div class="drift-summary" id="drift-summary"></div>
        <div class="drift-details" id="drift-details"></div>
    </div>

    <div class="summary">
        <div class="s-card"><div class="num">{{ summary.total_terms }}</div><div class="lbl">Total Terms</div></div>
        <div class="s-card"><div class="num">{{ summary.measures }}</div><div class="lbl">Measures</div></div>
        <div class="s-card"><div class="num">{{ summary.dimensions }}</div><div class="lbl">Dimensions</div></div>
    </div>

    <div class="tabs">
        <button class="tab active" data-tab="diagram">Model Diagram</button>
        <button class="tab" data-tab="terms">All Terms</button>
    </div>

    <!-- ===================== DIAGRAM TAB ===================== -->
    <div id="tab-diagram" class="tab-content active">
        <div class="diagram-wrap">
            <div class="diagram">
                {% for model in hierarchy %}
                <div class="model-box">
                    <div class="model-label">Model: {{ model.name }}</div>
                    {% if model.summary %}
                    <div style="font-size:.9rem;color:var(--muted);margin-bottom:1rem;line-height:1.5;background:#f0f4ff;padding:.75rem 1rem;border-radius:8px">{{ model.summary }}</div>
                    {% endif %}

                    {% if model.explores %}
                    <div class="explore-row">
                        {% for exp in model.explores %}
                        <div class="explore-box">
                            <div class="explore-label">Explore: {{ exp.label }}</div>
                            <div style="font-size:.82rem;color:var(--muted)">{{ exp.description }}</div>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <div class="arrow-down">&#9660; contains views</div>

                    <div class="views-row">
                        {% for view in model.views %}
                        <div class="view-box">
                            <div class="view-label">{{ view.label }}</div>
                            {% if view.table_name %}
                            <div class="view-table">{{ view.table_name }}</div>
                            {% endif %}

                            {% if view.measures %}
                            <div class="field-section">
                                <div class="field-section-title metric">&#9679; Measures ({{ view.measures | length }})</div>
                                {% for f in view.measures %}
                                <span class="field-pill metric">{{ f.name }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}

                            {% if view.dimensions %}
                            <div class="field-section">
                                <div class="field-section-title dim">&#9679; Dimensions ({{ view.dimensions | length }})</div>
                                {% for f in view.dimensions %}
                                <span class="field-pill dim">{{ f.name }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- ===================== TERMS TAB ===================== -->
    <div id="tab-terms" class="tab-content">
        <div class="toolbar">
            <input type="text" class="search-box" id="search" placeholder="Search terms...">
            <div class="filter-group">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="measure">Measures</button>
                <button class="filter-btn" data-filter="dimension">Dimensions</button>
            </div>
            <button class="btn btn-primary" id="download-csv">&#11123; Download CSV</button>
        </div>

        <table>
            <thead>
                <tr>
                    <th>Term Name</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Related Entries</th>
                    <th>Related Terms</th>
                    <th>Links</th>
                </tr>
            </thead>
            <tbody id="terms-body">
                {% for t in all_terms %}
                <tr data-type="{{ t.type }}" id="term-{{ t.field_id | replace('.', '-') }}">
                    <td><strong>{{ t.term_name }}</strong></td>
                    <td>
                        {% if t.type == 'dimension' %}
                        <span class="badge badge-dimension">Dimension</span>
                        {% else %}
                        <span class="badge badge-measure">Measure</span>
                        {% endif %}
                    </td>
                    <td>{{ t.description }}
                        {% if t.get('measure_type') %}
                        <br><small style="color:var(--muted)">measure type: {{ t.measure_type }}</small>
                        {% endif %}
                        {% if t.get('sql_expression') %}
                        <br><code>{{ t.sql_expression }}</code>
                        {% endif %}
                        {% if t.get('aspects') %}
                        {% for a in t.aspects %}{% if a.key == 'joins' %}
                        <br><span style="display:inline-block;margin-top:4px;padding:2px 8px;background:#e3f2fd;border-radius:6px;font-size:.8rem;color:#1565c0">Joins: {{ a.value }}</span>
                        {% endif %}{% endfor %}
                        {% endif %}
                    </td>
                    <td>{% if t.get('related_entries') %}{% for re in t.related_entries %}<code>{{ re.name }}</code>{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}</td>
                    <td>
                        {% if t.get('related_terms') %}
                        {% for r in t.related_terms %}
                        <a href="#term-{{ r.field_id | replace('.', '-') }}" class="field-pill" style="text-decoration:none;cursor:pointer">{{ r.term_name }}</a>
                        {% endfor %}
                        {% endif %}
                    </td>
                    <td>
                        {% if t.get('dashboard_links') %}
                        <ul class="links-list">
                            {% for lnk in t.dashboard_links %}
                            <li><a href="{{ lnk.url }}">{{ lnk.title }}</a></li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                        {% if t.get('recommended_links') %}
                        <ul class="links-list">
                            {% for lnk in t.recommended_links %}
                            <li><a href="{{ lnk.url }}">{{ lnk.title }}</a></li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
// Tabs
document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
    });
});

// Search & filter
const rows = document.querySelectorAll('#terms-body tr');
let activeFilter = 'all';

function applyFilters() {
    const q = document.getElementById('search').value.toLowerCase();
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const type = row.dataset.type;
        let typeMatch = activeFilter === 'all' || type === activeFilter;
        row.style.display = (text.includes(q) && typeMatch) ? '' : 'none';
    });
}

document.getElementById('search').addEventListener('input', applyFilters);
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeFilter = btn.dataset.filter;
        applyFilters();
    });
});

// CSV download
document.getElementById('download-csv').addEventListener('click', () => {
    const csvColumns = {{ csv_columns | tojson }};
    const csvRows = {{ csv_rows | tojson }};
    let csvContent = csvColumns.join(',') + '\n';
    csvRows.forEach(row => {
        csvContent += csvColumns.map(col => {
            let val = (row[col] || '').toString().replace(/"/g, '""');
            return '"' + val + '"';
        }).join(',') + '\n';
    });
    const blob = new Blob([csvContent], {type: 'text/csv;charset=utf-8;'});
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'lookml_glossary.csv';
    link.click();
    URL.revokeObjectURL(link.href);
});

// Drift notification
(function() {
    const banner = document.getElementById('drift-banner');
    const dismissBtn = document.getElementById('drift-dismiss');

    dismissBtn.addEventListener('click', function() {
        banner.style.display = 'none';
        try { sessionStorage.setItem('drift-dismissed', '1'); } catch(e) {}
    });

    if (sessionStorage.getItem('drift-dismissed') === '1') return;

    fetch('drift_report.json')
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(data) {
            if (!data || !data.summary) return;
            var s = data.summary;
            var drift = data.drift || [];

            banner.style.display = 'block';

            if (s.total === 0) {
                banner.className = 'drift-banner no-drift';
                document.getElementById('drift-icon').textContent = '\u2705';
                document.getElementById('drift-title').textContent = 'Glossary is up to date';
                document.getElementById('drift-summary').textContent = 'No drift detected \u2014 all terms match the current LookML source.';
                return;
            }

            if (s.errors > 0) {
                banner.className = 'drift-banner has-errors';
                document.getElementById('drift-icon').textContent = '\u26A0\uFE0F';
                document.getElementById('drift-title').textContent = 'Glossary drift detected';
            } else {
                banner.className = 'drift-banner';
                document.getElementById('drift-icon').textContent = '\u2139\uFE0F';
                document.getElementById('drift-title').textContent = 'Glossary updated';
            }

            var parts = [];
            if (s.errors > 0) parts.push(s.errors + ' error' + (s.errors > 1 ? 's' : ''));
            if (s.warnings > 0) parts.push(s.warnings + ' warning' + (s.warnings > 1 ? 's' : ''));
            if (s.info > 0) parts.push(s.info + ' info');
            document.getElementById('drift-summary').textContent =
                'The LookML model changed since the last glossary snapshot: ' + parts.join(', ') + '. The glossary has been regenerated to reflect the latest state.';

            if (drift.length > 0) {
                var html = '<details><summary>View ' + drift.length + ' change' + (drift.length > 1 ? 's' : '') + '</summary>';
                html += '<table class="drift-table"><thead><tr><th>Severity</th><th>Category</th><th>Field</th><th>Message</th></tr></thead><tbody>';
                for (var i = 0; i < drift.length; i++) {
                    var d = drift[i];
                    var cls = 'sev-' + d.severity;
                    html += '<tr><td class="' + cls + '">' + d.severity + '</td>';
                    html += '<td>' + d.category + '</td>';
                    html += '<td><code>' + d.field_id + '</code></td>';
                    html += '<td>' + d.message + '</td></tr>';
                }
                html += '</tbody></table></details>';
                document.getElementById('drift-details').innerHTML = html;
            }
        })
        .catch(function() {});
})();
</script>
</body>
</html>
